# API Settings
PROJECT_NAME="ML Model API Server"
PROJECT_DESCRIPTION="A FastAPI server for deploying machine learning models as APIs"
VERSION="0.1.0"

# Server Settings
HOST="0.0.0.0"
PORT=8000
DEBUG=true

# CORS Settings
ALLOWED_HOSTS="*"

# Model Settings
# MODEL_PATH="/path/to/custom/models"

# OpenAI Settings
OPENAI_API_KEY="your-openai-api-key-here"
OPENAI_MODEL_NAME="gpt-3.5-turbo"
OPENAI_TEMPERATURE=0.6
OPENAI_MAX_TOKENS=500

# MongoDB Settings
MONGODB_URL="mongodb://localhost:27017"
MONGODB_DATABASE="persian_agriculture_db"
MONGODB_CONVERSATIONS_COLLECTION="conversations"
CONVERSATION_TTL_DAYS=365